# ============================================================
# NutriPlanner Pro — Variables de entorno
# Copia este archivo como .env.local para desarrollo local
# En Netlify: Site settings → Environment variables
# NUNCA subas este archivo a Git (está en .gitignore)
# ============================================================

# --- SUPABASE ---
# Obtenlos en: app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para Netlify Functions (backend) — NO prefix VITE_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- STRIPE ---
# Obtenlos en: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...        # o pk_test_ para pruebas
STRIPE_SECRET_KEY=sk_live_...                  # o sk_test_ para pruebas

# Price IDs — Stripe Dashboard → Products
# Básico:  10€/mes
# Pro:     25€/mes
# Premium: 50€/mes
VITE_STRIPE_PRICE_BASICO=price_xxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxx

# Webhook secret — Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxx

# --- APP ---
VITE_APP_URL=https://ceresnutri.netlify.app
